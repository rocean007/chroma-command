PORT=3001
FRONTEND_URL=http://localhost:5173
# FIX: comma-separated; WebSocket Origin must match one of these (browser clients)
WS_ALLOWED_ORIGINS=http://localhost:5173
# FIX: set to 1 behind nginx/ingress so rate limits use X-Forwarded-For safely
TRUST_PROXY=0
# UNHACKABLE: throttle abusive single-endpoint WS fan-out (per IPv4/IPv6 string key)
MAX_WS_PER_IP=20
MAX_WS_MSG_BYTES=16384
WS_RATE_VIOLATIONS_BEFORE_CLOSE=40
MAX_WSS_CLIENTS=800
# UNHACKABLE: HSTS — only after TLS (e.g. reverse proxy). BREAKING on raw HTTP dev.
ENABLE_HSTS=0
MAX_QUEUE_SIZE=100
MATCH_TIMEOUT_MS=60000
LEADERBOARD_SIZE=100
NODE_ENV=development
